          "type": "host",
          "value": "salvaragardunha.hexgeta.com"
        }
      ],
      "destination": "https://salvargardunha.com/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "salvargardunha.hexgeta.com"
        }
      ],
      "destination": "https://salvargardunha.com/$1",
      "permanent": true
    },
    {
